# ═══════════════════════════════════════════════════
# Сервер
# ═══════════════════════════════════════════════════
# Внутренний порт ARMory внутри Docker.
# Не открывайте его наружу — публичный доступ обрабатывает шлюз авторизации.
PORT=5005

# ═══════════════════════════════════════════════════
# Шлюз авторизации (oauth2-proxy)
# ═══════════════════════════════════════════════════
# Публичный порт шлюза авторизации. Оркестратор проксирует
# armory.team-73.ru на этот порт.
GATEWAY_PORT=5005

# OIDC-учётные данные клиента из Stalwart (mail.team-73.ru).
# Запросите client_secret у администратора.
OAUTH2_PROXY_CLIENT_ID=armory
OAUTH2_PROXY_CLIENT_SECRET=

# Секрет куки для сессий oauth2-proxy.
# Должен быть base64-закодированным 32-байтным ключом.
# Сгенерировать: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=,profile,email

# ═══════════════════════════════════════════════════
# База данных
# ═══════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./data/armory.db

# ═══════════════════════════════════════════════════
# Хранилище
# ═══════════════════════════════════════════════════
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# S3 / MinIO (раскомментируйте при необходимости)
# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGNED_EXPIRES=3600

# ═══════════════════════════════════════════════════
# Синхронизация с Яндекс.Диском и бэкапы
# ═══════════════════════════════════════════════════
YANDEX_DISK_TOKEN=
YANDEX_DISK_PATH=ARMory/data
YANDEX_DISK_BACKUPS_PATH=ARMory/backups

# ═══════════════════════════════════════════════════
# Часовой пояс для меток времени бэкапов
# ═══════════════════════════════════════════════════
TIMEZONE=Europe/Moscow

# ═══════════════════════════════════════════════════
# Alexandrite — файловое хранилище заметок (.md и др.)
# Может указывать на папку Obsidian или любую другую.
# По умолчанию используется отдельная папка data/alexandrite.
# ═══════════════════════════════════════════════════
ALEXANDRITE_VAULT_PATH=./data/alexandrite

# Путь к папке Alexandrite на Яндекс.Диске (для синхронизации и архивов)
YANDEX_DISK_ALEXANDRITE_PATH=ARMory/alexandrite

# Ограничение просмотра Яндекс.Диска в Alexandrite указанной папкой.
# • ALEXANDRITE_YANDEX_ROOT_PATH= — весь Яндекс.Диск.
# • ALEXANDRITE_YANDEX_ROOT_PATH=ARMory — только содержимое ARMory/.
# • ALEXANDRITE_YANDEX_ROOT_PATH=ARMory/alexandrite — только папка ARMory/alexandrite.
# Если не задано — доступен весь диск. Для ограничения только папкой ARMory:
# ALEXANDRITE_YANDEX_ROOT_PATH=ARMory
ALEXANDRITE_YANDEX_ROOT_PATH=

# ═══════════════════════════════════════════════════
# Telegram-уведомления о событиях календаря
# ═══════════════════════════════════════════════════
TELEGRAM_REMINDER_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════════════
# Пути к проектам со скриптами (через запятую, ~ разворачивается в $HOME)
# На проде пути указываются так, как они выглядят на целевом сервере.
# ═══════════════════════════════════════════════════
SCRIPTS_PROJECT_PATHS=~/scripts/scripts

# SSH-доступ к серверам со скриптами (прод, Docker).
# Формат: проект=user@host через запятую; проект — имя каталога из SCRIPTS_PROJECT_PATHS.
# Проекты без записи выполняются локально (режим разработки).
# SCRIPTS_PROJECT_SSH=dcript=user@192.168.1.10,flat-parser=user@192.168.1.20
SCRIPTS_PROJECT_SSH=

# Путь к приватному ssh-ключу ВНУТРИ контейнера (монтируется через compose).
SCHEDULER_SSH_KEY=/app/ssh/id_ed25519

# Путь к тому же ключу на ХОСТЕ (используется в compose.yml для монтирования).
# Публичную часть ключа добавьте в authorized_keys пользователя на каждом сервере.
# Сгенерировать: ssh-keygen -t ed25519 -f deploy/id_ed25519 -N ""
SCHEDULER_SSH_KEY_HOST=./deploy/id_ed25519

# ═══════════════════════════════════════════════════
# Публичный URL ARMory (нужен для WOPI / Collabora)
# ═══════════════════════════════════════════════════
ARMORY_PUBLIC_URL=https://armory.team-73.ru

# ═══════════════════════════════════════════════════
# Collabora Online — редактирование документов в Alexandrite
# ═══════════════════════════════════════════════════
COLLABORA_ENABLED=false
COLLABORA_DOMAIN=armory.team-73.ru
# Внутренний URL изнутри Docker-сети ARMory
COLLABORA_INTERNAL_URL=http://collabora:9980
# Публичный URL, по которому пользователь обращается к Collabora
# При варианте A (через ARMory proxy) оставьте /collabora
COLLABORA_PUBLIC_URL=https://armory.team-73.ru/collabora
# Внутренний адрес ARMory, по которому контейнер Collabora забирает файлы (WOPI).
# app и collabora — в одной docker-сети; публичный адрес изнутри недоступен (hairpin).
# Порт должен совпадать с PORT этого .env.
COLLABORA_WOPI_INTERNAL_URL=http://app:5005
# Префикс пути для Collabora (должен совпадать с net.service_root в extra_params)
COLLABORA_SERVICE_ROOT=/collabora
# Секрет для подписи WOPI access token
# Сгенерировать: openssl rand -hex 32
COLLABORA_WOPI_SECRET=
# Учётные данные админ-панели Collabora (/browser/dist/admin/admin.html)
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=changeme

# ═══════════════════════════════════════════════════
# PocketBase
# ═══════════════════════════════════════════════════
# Внутренний URL изнутри Docker-сети ARMory
POCKETBASE_INTERNAL_URL=http://pocketbase:8090
# Публичный путь, по которому админка PocketBase доступна через ARMory
POCKETBASE_PUBLIC_PATH=/pocketbase/
# Учётные данные суперпользователя PocketBase (автосоздаются при старте)
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=changeme
