# ═══════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════
# Internal port used by ARMory inside Docker.
# Do not expose it directly — the auth gateway handles public access.
PORT=5005

# ═══════════════════════════════════════════════════
# Auth Gateway (rusty-auth-gateway)
# ═══════════════════════════════════════════════════
# Public port for the auth gateway. The orchestrator proxies
# armory.team-73.ru to this port.
GATEWAY_PORT=5005

# Strong secret for encrypted session cookies (min 32 characters).
GATEWAY_COOKIE_SECRET=replace-me-with-a-strong-secret-at-least-32-chars
GATEWAY_COOKIE_NAME=gateway_session
GATEWAY_SESSION_TTL=1h
GATEWAY_LOGIN_MODE=auto

# Provider used for authentication.
# For team-73.ru set this to: oidc
GATEWAY_ENABLED_PROVIDERS=

GATEWAY_UI_LOCALE=ru

# ═══════════════════════════════════════════════════
# OIDC via Stalwart Mail Server
# ═══════════════════════════════════════════════════
# Stalwart acts as the OIDC provider for team-73.ru services.
# Forgejo already uses it with:
#   issuer:        http://10.1.1.14/
#   discovery:     http://10.1.1.14/.well-known/openid-configuration
#   client_id:     forgejo
# Ask your admin whether ARMory should reuse the forgejo credentials
# or can use its own client_id (armory).
OIDC_ISSUER_URL=http://10.1.1.14/
OIDC_CLIENT_ID=armory
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://armory.team-73.ru/callback/oidc
OIDC_SCOPES=openid,profile,email

# ═══════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./projectdocs.db

# ═══════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# S3 / MinIO (раскомментируйте при необходимости)
# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGNED_EXPIRES=3600

# ═══════════════════════════════════════════════════
# Yandex Disk sync & backups
# ═══════════════════════════════════════════════════
YANDEX_DISK_TOKEN=
YANDEX_DISK_PATH=ARMory/data
YANDEX_DISK_BACKUPS_PATH=ARMory/backups

# ═══════════════════════════════════════════════════
# Timezone for backup timestamps
# ═══════════════════════════════════════════════════
TIMEZONE=Europe/Moscow

# ═══════════════════════════════════════════════════
# Scripts projects paths (через запятую, ~ разворачивается в $HOME)
# ═══════════════════════════════════════════════════
SCRIPTS_PROJECT_PATHS=~/scripts/ssk-scraper
