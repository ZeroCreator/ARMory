# ═══════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./projectdocs.db

# ═══════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# S3 / MinIO (раскомментируйте при необходимости)
# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGNED_EXPIRES=3600

# ═══════════════════════════════════════════════════
# Scripts projects paths (через запятую)
# ═══════════════════════════════════════════════════
SCRIPTS_PROJECT_PATHS=/home/zerocreator/scripts/ssk-scraper
