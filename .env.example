# ═══════════════════════════════════════════════════
# Server
# ═══════════════════════════════════════════════════
# Internal port used by ARMory inside Docker.
# Do not expose it directly — the auth gateway handles public access.
PORT=5005

# ═══════════════════════════════════════════════════
# Auth Gateway (oauth2-proxy)
# ═══════════════════════════════════════════════════
# Public port for the auth gateway. The orchestrator proxies
# armory.team-73.ru to this port.
GATEWAY_PORT=5005

# OIDC client credentials from Stalwart (mail.team-73.ru).
# Ask your admin for the client_secret.
OAUTH2_PROXY_CLIENT_ID=armory
OAUTH2_PROXY_CLIENT_SECRET=

# Cookie secret for oauth2-proxy sessions.
# Must be a base64-encoded 32-byte key.
# Generate with: openssl rand -base64 32
OAUTH2_PROXY_COOKIE_SECRET=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=,profile,email

# ═══════════════════════════════════════════════════
# Database
# ═══════════════════════════════════════════════════
DATABASE_URL=sqlite+aiosqlite:///./projectdocs.db

# ═══════════════════════════════════════════════════
# Storage
# ═══════════════════════════════════════════════════
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./data/uploads

# S3 / MinIO (раскомментируйте при необходимости)
# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1
# S3_FORCE_PATH_STYLE=false
# S3_PRESIGNED_EXPIRES=3600

# ═══════════════════════════════════════════════════
# Yandex Disk sync & backups
# ═══════════════════════════════════════════════════
YANDEX_DISK_TOKEN=
YANDEX_DISK_PATH=ARMory/data
YANDEX_DISK_BACKUPS_PATH=ARMory/backups

# ═══════════════════════════════════════════════════
# Timezone for backup timestamps
# ═══════════════════════════════════════════════════
TIMEZONE=Europe/Moscow

# ═══════════════════════════════════════════════════
# Scripts projects paths (через запятую, ~ разворачивается в $HOME)
# ═══════════════════════════════════════════════════
SCRIPTS_PROJECT_PATHS=~/scripts/ssk-scraper
